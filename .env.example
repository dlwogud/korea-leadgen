# Copy to `.env` (gitignored) and fill in the keys you have.
#   cp .env.example .env
# You can also set these from the admin panel (Settings tab) — it writes here.

# ── Required for the AI steps (qualify / outreach drafts / EN translation) ──
# Needs a funded balance, not just a key. https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Firmographics: official employee count from DART (금융감독원 전자공시) ──
# Free, instant key. Covers listed + external-audit firms.
# https://opendart.fss.or.kr  →  인증키 신청/관리
DART_API_KEY=

# ── Optional alternate job source (not required; Wanted is the primary) ──
# Free Saramin Open API key: https://oapi.saramin.co.kr
SARAMIN_API_KEY=

# ── Future enrichment (plug in when obtained) ──
# 국민연금 가입 사업장 (broad headcount coverage): https://www.data.go.kr
# NPS_API_KEY=
# JobKorea / Wanted official APIs — require a Korean business entity:
# JOBKOREA_API_KEY=
# WANTED_API_KEY=
